import { Notification, NotificationInfo, NotificationType } from "components/notification.slint";
export { NotificationInfo }

// Fields import
import { ConnectionFiled } from "fields/connection.slint";
import { AuthorizationField } from "fields/authorization.slint";
import { BaseField } from "fields/base.slint";

export enum AppStates { Connection, Authorization }

export component MainWindow inherits Window {
    in-out property <AppStates> state: Connection;

    private property <duration> show-hide-duration: 400ms;

    title: "mhserver-client";
    width: 1280px;
    height: 720px;
    background: #2d2a29;

    main_notification := Notification {
        x: root.width - self.width - 20px;
        y: root.height - self.height - 20px;
        hided: true;
    }

    // Disabled by default
    field := BaseField {
        width: 300px;
        enabled: false;
        change-duration: show-hide-duration;

        conn_field := ConnectionFiled {
            height: 250px;
            showed: false;
            change-duration: show-hide-duration;
        }

        auth_field := AuthorizationField {
            height: 300px;
            showed: false;
            change-duration: show-hide-duration;

            auth => {
                state = AppStates.Connection;
            }
        }
    }
    
    // Main notification
    callback update_main_notification <=> main_notification.update;

    // Connection field
    callback connect <=> conn_field.connect;

    states [
        connection when state == AppStates.Connection: {
            field.enabled: true;
            field.height: conn_field.height + 10px;
            conn_field.showed: true;
        }

        authorization when state == AppStates.Authorization: {
            field.enabled: true;
            field.height: auth_field.height + 10px;
            auth_field.showed: true;
        }
    ]
}
