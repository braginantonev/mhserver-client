import { Notification, NotificationInfo, NotificationType } from "notification.slint";
export { NotificationInfo }

import { ConnectionFiled } from "connection.slint";

export enum AppStates { Connection, Authorization }

export component MainWindow inherits Window {
    in-out property <AppStates> state: Connection;  

    title: "mhserver-client";
    width: 1280px;
    height: 720px;
    background: #2d2a29;

    main_notification := Notification {
        x: root.width - self.width - 20px;
        y: root.height - self.height - 20px;
        hided: true;
    }

    conn_field := ConnectionFiled {
        width: 300px;
        height: 250px;
        x: self.width + root.width;
        enabled: false;
    }

    // Main notification
    callback update_main_notification <=> main_notification.update;

    // Connection field
    callback connect <=> conn_field.connect;

    states [
        connection when state == AppStates.Connection: {
            conn_field.enabled: true;
            conn_field.x: root.width / 2 - conn_field.width / 2;
        }
    ]
}
