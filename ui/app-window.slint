import { Notification, NotificationInfo, NotificationType } from "components/notification.slint";
export { NotificationInfo }

// Fields import
import { ConnectionFiled } from "fields/connection.slint";
import { LoginField, RegisterField } from "fields/authorization.slint";
import { FieldBackground } from "fields/base.slint";
import { Button } from "std-widgets.slint";
import { ServiceField } from "fields/service.slint";

export enum PreparingStates { Normal, End, CheckConn, CheckAuth, Connection, Login, Register }
export enum AppStates { Preparing, Main }

export component MainWindow inherits Window {
    in-out property <AppStates> state: Main;
    in-out property <PreparingStates> prepare-state: Normal;

    private property <duration> show-hide-duration: 400ms;

    title: "mhserver-client";
    width: 1280px;
    height: 720px;
    background: #2d2a29;

    main_notification := Notification {
        x: root.width - self.width - 20px;
        y: root.height - self.height - 20px;
        hided: true;
    }

    // Fields
    Rectangle {
        width: 300px;

        field_back := FieldBackground {
            field-color: #0b0b0b80;
            enabled: false;
            change-duration: show-hide-duration;
        }

        conn_field := ConnectionFiled {
            showed: false;
            change-duration: show-hide-duration;
        }

        log_field := LoginField {
            showed: false;
            change-duration: show-hide-duration;
            register_request => { prepare-state = PreparingStates.Register };
        }

        reg_field := RegisterField {
            showed: false;
            change-duration: show-hide-duration;
            login_request => { prepare-state = PreparingStates.Login };
        }
    }

    service_field := ServiceField {
        x: 0px;
        enabled: false;
    }

    // For a smooth startup
    Timer {
        interval: 250ms;
        running: false;
        triggered => {
            self.running = false;

            // Use this callback to start preparing logic
            change_preparing_state(PreparingStates.Normal);
        }
    }

    callback change_preparing_state(PreparingStates);

    // Main notification
    callback update_main_notification <=> main_notification.update;

    // Connection field
    callback connect <=> conn_field.connect;

    // Authorization field
    callback login <=> log_field.login;
    callback register <=> reg_field.register;

    states [
        conn when state == AppStates.Preparing && prepare-state == PreparingStates.Connection: {
            field_back.enabled: true;
            field_back.height: conn_field.height;
            conn_field.showed: true;
        }

        login when state == AppStates.Preparing && prepare-state == PreparingStates.Login: {
            field_back.enabled: true;
            field_back.height: log_field.height;
            log_field.showed: true;
        }

        reg when state == AppStates.Preparing && prepare-state == PreparingStates.Register: {
            field_back.enabled: true;
            field_back.height: reg_field.height;
            reg_field.showed: true;
        }
        
        main when state == AppStates.Main: {
            service_field.enabled: true;
        }
    ]
}
